# ──────────────────────────────────────────────────────────────────────────
# Plataforma Creativa IA · Grupo Zapata — variables de entorno
# Copia a `.env.local` y rellena. NUNCA comitees secretos reales.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Proveedores de IA ───────────────────────────────────────────────────────
# MODO ARRANQUE: solo Gemini activo. Su llave es la UNICA requerida.
GOOGLE_GENERATIVE_AI_API_KEY=
# Modelos de Gemini (proveedor activo; config-driven)
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_IMAGE=imagen-3.0-generate-002

# Claude / OpenAI: soporte definido pero INACTIVO. Opcionales; rellena su llave
# y enruta la tarea en routeModel para reactivarlos (sin tocar dominio ni adapter).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL_HIGH=claude-opus-4-8
AI_MODEL_BALANCED=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5

# ── Supabase: SOLO Postgres + Auth + RLS (NO se usa para imagenes) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo backend / migraciones. Jamas se expone al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare R2 (S3-compatible) — imagenes generadas por IA ───────────────
# Egress $0: mucho mas barato a escala para servir imagenes que Supabase Storage.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Dominio publico del bucket (o dominio propio). Solo para assets no sensibles;
# las imagenes se sirven por URL firmada.
R2_PUBLIC_BASE_URL=
